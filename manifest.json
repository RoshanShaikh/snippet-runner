{
  "manifest_version": 3,
  "name": "SnippetRunner",
  "version": "1.1.0",
  "description": "Store JS snippets with configurable variables and run them in any page's console.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnippetRunner"
  },
  "web_accessible_resources": [
    {
      "resources": ["editor.html", "results.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}